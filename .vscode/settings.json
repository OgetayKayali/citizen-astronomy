{
    "python.defaultInterpreterPath": "${workspaceFolder}\\.venv\\Scripts\\python.exe",
    "python-envs.defaultEnvManager": "ms-python.python:system",

    "python.analysis.nodeArguments": [
        "--max-old-space-size=32768"
    ],

    "python.analysis.exclude": [
        "**/.venv",
        "**/venv",
        "**/__pycache__",
        "**/.pytest_cache",
        "**/build",
        "**/dist",
        "**/Exports",
        "**/data",
        "**/outputs",
        "**/cache"
    ],

    "files.exclude": {
        "**/.venv": true,
        "**/__pycache__": true,
        "**/.pytest_cache": true,
        "**/hr_field_catalog.json": true,
        "**/hr_working_table.json": true,
        "**/hr_working_table.csv": true
    },

    "search.exclude": {
        "**/.venv": true,
        "**/venv": true,
        "**/__pycache__": true,
        "**/.pytest_cache": true,
        "**/build": true,
        "**/dist": true,
        "**/Exports": true,
        "**/data": true,
        "**/outputs": true,
        "**/cache": true,
        "**/hr_field_catalog.json": true,
        "**/hr_working_table.json": true,
        "**/hr_working_table.csv": true,
        "**/*.h5": true,
        "**/*.hdf5": true,
        "**/*.fits": true,
        "**/*.fit": true,
        "**/*.xisf": true,
        "**/*.tif": true,
        "**/*.tiff": true,
        "**/*.png": true,
        "**/*.jpg": true,
        "**/*.jpeg": true,
        "**/*.mp4": true,
        "**/*.avi": true
    },

    "files.watcherExclude": {
        "**/.venv/**": true,
        "**/venv/**": true,
        "**/__pycache__/**": true,
        "**/.pytest_cache/**": true,
        "**/build/**": true,
        "**/dist/**": true,
        "**/Exports/**": true,
        "**/data/**": true,
        "**/outputs/**": true,
        "**/cache/**": true,
        "**/hr_field_catalog.json": true,
        "**/hr_working_table.json": true,
        "**/hr_working_table.csv": true,
        "**/*.h5": true,
        "**/*.hdf5": true,
        "**/*.fits": true,
        "**/*.fit": true,
        "**/*.xisf": true,
        "**/*.tif": true,
        "**/*.tiff": true,
        "**/*.png": true,
        "**/*.jpg": true,
        "**/*.jpeg": true,
        "**/*.mp4": true,
        "**/*.avi": true
    }
}