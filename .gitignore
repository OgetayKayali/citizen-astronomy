__pycache__/
.pytest_cache/
.venv/
*.pyc
dist/
build/
*.egg-info/

# All temporary build/smoke/test outputs
_tmp_*/
_tmp_*
.tmp_*

# Photometry measurement and catalog caches
.photometry-cache/

# Demo/sample FITS data
Files/

# Large runtime assets (bundled by PyInstaller at build time)
assets/milky_way_tiles/
assets/milky_way_tiles_lzw/
assets/moon_tiles/
assets/moon_tiles_synthetic/
assets/spice/kernels/

# Rendered milky way tile trees (built from source data, very large)
textures/milky_way_tiles_*/

# Large source textures (too big for GitHub, obtain separately)
textures/milkyway_2020_32k.exr
textures/milkyway_2020_4k.exr
textures/moon_lroc_color_16bit_srgb_8k.tif
textures/moon_ldem_16.tif

# Sky survey overlay cache
survey/

# Packaging build outputs
packaging/dist/

# Benchmark result outputs (very large JSON files)
benchmark_results/
benchmark_results_*/

# Export outputs
Exports/

# Sky atlas large catalog data
sky-atlas/

# Git status dump (created during this session)
_git_status.txt
_git_status_dirs.txt

# IDE / editor (keep local, do not publish)
.cursor/
.vscode/

# One-off agent prompt drafts
star_instructions*.md

# Accidental shell/PowerShell artifact filenames
'@ + $outPath + @'

# Build and capture logs
*.log

# Ad-hoc command/test capture outputs at repo root
/*.txt
!requirements.txt
!requirements-*.txt

# Local HR working artifacts (regenerated by the app)
hr_working_table.csv
hr_working_table.json
hr_field_catalog.json

# Internal / non-user docs (manuscripts, AI agent maps, engineering notes)
docs/paper/
docs/ai/
docs/MOON_PHASE5*.md
docs/recovery_audit_*.md
docs/codebase_map_printable.*
docs/Doc_*.md
